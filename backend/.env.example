FREELLMAPI_BASE_URL=http://localhost:3001/v1
FREELLMAPI_API_KEY=freellmapi-your-unified-key-here
FREELLMAPI_MODEL=auto

# V5: knowledge graph + relational catalog
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your-neo4j-password
POSTGRES_DSN=postgresql://nexus:your-postgres-password@localhost:5432/nexus

# Auth: JWT signing key (generate with `python -c "import secrets; print(secrets.token_hex(32))"`)
JWT_SECRET_KEY=replace-with-a-random-64-char-hex-string
JWT_EXPIRE_MINUTES=1440
